# ─────────────────────────────────────────────
# Nexora AI — Environment Variables
# ─────────────────────────────────────────────

# AI Provider selection: "openai" or "nvidia"
AI_PROVIDER=openai

# OpenAI Configuration
# Use a real key in your local .env file; never commit secrets.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# NVIDIA Configuration
# Use a real key in your local .env file; never commit secrets.
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Backend server config
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Feature flags
ENABLE_CLIPBOARD_MONITOR=true
ENABLE_SCREENSHOT_CAPTURE=true
ENABLE_ERROR_WATCHER=true

# Overlay window settings
OVERLAY_WIDTH=420
OVERLAY_HEIGHT=600
OVERLAY_HOTKEY=CommandOrControl+Shift+Space